{
  "name": "@postline/tools-builtin",
  "description": "Built-in tools for postline: echo, web_fetch (SSRF-guarded), fs, memory (git-backed), github, lark_docs, feishu_send, bash_read, bash. Risk-tier gated.",
  "keywords": ["postline", "tools", "agent-tools", "claude"],
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
