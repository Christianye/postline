{
  "name": "@postline/adapters-telegram",
  "description": "Telegram channel adapter: getUpdates long-polling, message split, in-place edit, inline-keyboard approval, file download. Zero-dependency (plain Bot API over fetch).",
  "keywords": ["postline", "telegram", "channel-adapter", "bot-api"],
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
