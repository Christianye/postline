{
  "name": "postline-workspace",
  "description": "A Feishu/Lark bot framework powered by Claude — streaming, tool use, vision, git-backed memory, 24/7 systemd deployment.",
  "keywords": [
    "feishu",
    "lark",
    "claude",
    "anthropic",
    "bedrock",
    "bot",
    "ai-agent",
    "llm",
    "chatbot",
    "typescript"
  ],
  "homepage": "https://github.com/Christianye/postline",
  "repository": {
    "type": "git",
    "url": "https://github.com/Christianye/postline.git"
  },
  "bugs": {
    "url": "https://github.com/Christianye/postline/issues"
  },
  "license": "MIT",
  "author": "Christianye",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "chat": "pnpm -r build && pnpm --filter @postline/cli run chat",
    "start": "pnpm -r build && pnpm --filter @postline/cli run start",
    "doctor": "pnpm -r build && node packages/cli/dist/bin.js doctor",
    "ship:upgrade": "pnpm -r build && node packages/cli/dist/bin.js upgrade",
    "ship:init": "pnpm -r build && node packages/cli/dist/bin.js init"
  },
  "dependencies": {
    "@postline/config": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
