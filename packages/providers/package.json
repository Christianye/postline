{
  "name": "@postline/providers",
  "description": "LLM providers for postline: AWS Bedrock (Claude 4.x via @aws-sdk) and Anthropic API, with a tagged-union factory registry and fallback chain support.",
  "keywords": ["postline", "claude", "anthropic", "bedrock", "llm-provider"],
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bedrock": {
      "types": "./dist/bedrock/index.d.ts",
      "default": "./dist/bedrock/index.js"
    },
    "./anthropic": {
      "types": "./dist/anthropic/index.d.ts",
      "default": "./dist/anthropic/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@postline/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
