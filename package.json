{
  "name": "postline-workspace",
  "description": "The missing IM connector for Claude Code — bridge a Feishu/Lark, Telegram, or Slack bot to your existing Claude Code (or Codex) sessions and dispatch coding tasks from chat.",
  "keywords": [
    "claude-code",
    "feishu",
    "lark",
    "telegram",
    "slack",
    "claude",
    "anthropic",
    "bedrock",
    "bot",
    "ai-agent",
    "llm",
    "typescript"
  ],
  "homepage": "https://github.com/Christianye/postline",
  "repository": {
    "type": "git",
    "url": "https://github.com/Christianye/postline.git"
  },
  "bugs": {
    "url": "https://github.com/Christianye/postline/issues"
  },
  "license": "MIT",
  "author": "Christianye",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "chat": "pnpm -r build && pnpm --filter @postline/cli run chat",
    "start": "pnpm -r build && pnpm --filter @postline/cli run start",
    "doctor": "pnpm -r build && node packages/cli/dist/bin.js doctor",
    "ship:upgrade": "pnpm -r build && node packages/cli/dist/bin.js upgrade",
    "ship:init": "pnpm -r build && node packages/cli/dist/bin.js init",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@postline/config": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
