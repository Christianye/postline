{
  "name": "@postline/skill-loader",
  "description": "Claude Code skill loader for postline. Reads ~/.claude/skills/<name>/SKILL.md files, parses frontmatter, and exposes each skill as a `skill_<name>` tool that returns its instructional content for the model to follow.",
  "keywords": ["postline", "claude", "claude-code", "skills"],
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
