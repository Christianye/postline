{
  "name": "@postline/adapters-slack",
  "description": "Slack channel adapter: Socket Mode (no inbound port), message split, in-place update, Block Kit approval, file info. Zero-dependency (Web API over fetch + native WebSocket).",
  "keywords": ["postline", "slack", "channel-adapter", "socket-mode"],
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
