# Legacy env-based config (Phase 1 compatibility path).
# New deployments should use postline.config.ts — see postline.config.example.ts.
#
# Copy this to `~/.cc/env` on the EC2 host or `~/.cc-dev/.env` on your dev machine.
# NEVER commit the real file with real values.

# === Feishu app ===
CC_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
CC_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional; auto-fetched via /bot/v3/info if absent
# CC_FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Identity / allowlist ===
# Comma-separated open_id list — only these users can trigger write-tier tools
CC_ALLOWLIST_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Provider + model ===
AWS_REGION=us-west-2
CC_PRIMARY_MODEL=amazon-bedrock/us.anthropic.claude-opus-4-7
CC_FALLBACK_MODELS=amazon-bedrock/global.anthropic.claude-sonnet-4-6,amazon-bedrock/us.anthropic.claude-opus-4-6-v1

# === Memory ===
CC_MEMORY_DIR=/home/ubuntu/.cc/memory

# === Logging ===
CC_LOG_LEVEL=info

# === Optional: openclaw bridge (requires a co-located openclaw agent) ===
# CC_OPENCLAW_TOKEN=<gateway auth token from ~/.openclaw/openclaw.json>
# CC_OPENCLAW_URL=ws://localhost:18789
# CC_OPENCLAW_SESSION=cc-collab
# CC_OPENCLAW_BIN=/absolute/path/to/openclaw  # needed when systemd PATH lacks nvm
