# postline docker-compose env. Copy to `.env` and fill values.
# Never commit your real `.env` — it lives next to the compose file but
# is in .gitignore.

# === Feishu app (required) ===
# Create at https://open.feishu.cn → Developer Console → 自建应用 → 凭证与基础信息.
# Enable "事件订阅" → "事件订阅模式" → "长连接" (long-poll WSClient mode).
# DO NOT configure a webhook URL — postline never accepts inbound HTTP.
CC_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
CC_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional; auto-fetched if absent.
# CC_FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Identity / allowlist (optional but recommended) ===
# Comma-separated open_id list — only these users trigger write/dangerous tools.
CC_ALLOWLIST_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === LLM provider + model (one of bedrock / anthropic) ===
# Bedrock path:
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
CC_PRIMARY_MODEL=amazon-bedrock/us.anthropic.claude-opus-4-7
CC_FALLBACK_MODELS=amazon-bedrock/global.anthropic.claude-sonnet-4-6,amazon-bedrock/us.anthropic.claude-opus-4-6-v1

# Anthropic API path (alternative; remove the AWS_* / Bedrock vars above):
# ANTHROPIC_API_KEY=sk-ant-...
# CC_PRIMARY_MODEL=anthropic/claude-opus-4-7

# === Memory ===
# CC_MEMORY_DIR is set by the Dockerfile to /data/memory. Override only if
# you mount the volume elsewhere.

# === Logging ===
CC_LOG_LEVEL=info
