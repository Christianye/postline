{
  "name": "@postline/mcp-client",
  "description": "Minimal Model Context Protocol (MCP) client for postline — stdio, Streamable HTTP, and SSE transports. Reads Claude Code-compatible mcpServers config, lists tools, and adapts them to postline Tool[] with configurable risk tiers.",
  "keywords": ["postline", "mcp", "model-context-protocol", "claude", "tools"],
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
