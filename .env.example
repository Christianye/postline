# Copy this to .env (in your dev machine) or ~/.cc/env (on EC2)
# NEVER commit the real .env

# === Feishu app ===
CC_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
CC_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Identity / allowlist ===
# Comma-separated open_id list — only these users can trigger write-tier tools
CC_ALLOWLIST_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Provider (default bedrock) ===
# One of: bedrock, anthropic, openrouter
CC_PROVIDER=bedrock
AWS_REGION=us-west-2
CC_PRIMARY_MODEL=amazon-bedrock/us.anthropic.claude-opus-4-7
CC_FALLBACK_MODELS=amazon-bedrock/global.anthropic.claude-sonnet-4-6,amazon-bedrock/us.anthropic.claude-opus-4-6-v1

# === Memory ===
CC_MEMORY_REPO=git@github.com:Christianye/claude-memory.git
CC_MEMORY_DIR=/home/ubuntu/.cc/memory

# === Logging ===
# none | metadata | full — default metadata (no message bodies)
CC_LOG_LEVEL=metadata
