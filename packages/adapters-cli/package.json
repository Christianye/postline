{
  "name": "@postline/adapters-cli",
  "description": "stdin/stdout CLI channel adapter — drives the postline turn loop from a local REPL for development without feishu.",
  "keywords": ["postline", "cli", "channel-adapter", "repl"],
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@postline/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
