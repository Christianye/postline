{
  "name": "@postline/adapters-feishu",
  "description": "Feishu / Lark channel adapter: long-connection WebSocket, @mention parsing, image download, message splitting, deduplication.",
  "keywords": ["postline", "feishu", "lark", "channel-adapter", "websocket"],
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
