{
  "name": "@postline/cli",
  "description": "Command-line entry: `postline chat | feishu | ask | upgrade | doctor | init | tools`. Loads config, wires provider + channel + tools + memory, runs the turn loop.",
  "keywords": ["postline", "cli", "claude"],
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "postline": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "chat": "node ./dist/bin.js chat",
    "start": "node ./dist/bin.js feishu"
  },
  "dependencies": {
    "@postline/adapters-cli": "workspace:*",
    "@postline/adapters-feishu": "workspace:*",
    "@postline/config": "workspace:*",
    "@postline/core": "workspace:*",
    "@postline/mcp-client": "workspace:*",
    "@postline/providers": "workspace:*",
    "@postline/skill-loader": "workspace:*",
    "@postline/tools-builtin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
