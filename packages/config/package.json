{
  "name": "@postline/config",
  "description": "PostlineConfig type, defineConfig() helper, and the config loader (postline.config.{ts,mjs,js} walk-up resolver with env-fallback).",
  "keywords": ["postline", "config", "typescript-config"],
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@postline/core": "workspace:*",
    "@postline/mcp-client": "workspace:*",
    "@postline/providers": "workspace:*",
    "@postline/skill-loader": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
